{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "env": {
            "value": "${AZURE_ENV_NAME}"
        },
        "location": {
            "value": "${AZURE_LOCATION}"
        },
        "deployScope": {
            "value": "${DEPLOY_SCOPE=data}"
        },
        "authMode": {
            "value": "${AUTH_MODE=stub}"
        },
        "entraTenantId": {
            "value": "${ENTRA_TENANT_ID=}"
        },
        "entraClientId": {
            "value": "${ENTRA_CLIENT_ID=}"
        },
        "entraSpaClientId": {
            "value": "${ENTRA_SPA_CLIENT_ID=}"
        },
        "entraGroupIdAdmin": {
            "value": "${ENTRA_GROUP_ID_ADMIN=}"
        }
    }
}
