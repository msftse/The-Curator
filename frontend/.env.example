# Frontend environment configuration.
#
# Copy to `.env.local` for local dev. Production values are set via the Static
# Web App's app settings during deploy (see `infra/README.md`).

# Backend API base URL — must be reachable from the browser.
NEXT_PUBLIC_API_BASE=http://localhost:8000

# Auth mode. Two values:
#   stub  — sends `X-User-Email` header. Only valid when the backend is
#           running with `LOCAL_DEV=1`. Used for local-dev with no Entra tenant.
#   oidc  — wires MSAL (Entra ID) redirect login + Bearer-token API calls.
NEXT_PUBLIC_AUTH_MODE=stub

# OIDC-only settings. Required when NEXT_PUBLIC_AUTH_MODE=oidc.
# Populated by `scripts/setup-entra.sh <env> <frontend-hostname>` output.
NEXT_PUBLIC_ENTRA_TENANT_ID=
NEXT_PUBLIC_ENTRA_CLIENT_ID=
NEXT_PUBLIC_ENTRA_API_SCOPE=
