# Copy to .env.local and source / let pydantic-settings pick it up.
# Defaults below target the local emulator stack (docker compose up).
# Real-Azure sections are commented; uncomment + fill to point at a cloud env.
# .env.local is gitignored — never commit real endpoints or keys.

# ---- Cosmos DB (emulator) ----
COSMOS_ENDPOINT=https://localhost:8081
# Well-known Cosmos emulator master key. Public knowledge, safe to commit.
COSMOS_KEY=C2y6yDjf5/R+ob0N8A7Cgv30VRDJIWEHLM+4QDU5DE2nQ9nDuVTqobD4b8mGGyPMbIZnqyMsEcaGQy67XIw/Jw==
COSMOS_DB_NAME=skillhub
# Local emulator uses a self-signed cert; skip TLS verification for dev only.
COSMOS_VERIFY_TLS=false
# ---- Cosmos DB (real Azure, passwordless) ----
# COSMOS_ENDPOINT=https://<account>.documents.azure.com:443/
# COSMOS_KEY=                # leave empty; DefaultAzureCredential is used
# COSMOS_VERIFY_TLS=true

# ---- Azurite (Blob) ----
# Two auth modes:
#   1. Connection string (Azurite / shared key). Leave BLOB_ACCOUNT_URL empty.
#   2. Identity (az login / Managed Identity). Set BLOB_ACCOUNT_URL to
#      https://<account>.blob.core.windows.net — the connection string is
#      ignored. `az login` from your shell is picked up by DefaultAzureCredential.
# Well-known Azurite dev connection string. Public knowledge.
BLOB_CONNECTION_STRING=DefaultEndpointsProtocol=http;AccountName=devstoreaccount1;AccountKey=Eby8vdM02xNOcqFlqUwJPLlmEtlCDXJ1OUzFT50uSRZ6IFsuFq2UVErCz4I6tq/K1SZFPTOtr/KBHBeksoGMGw==;BlobEndpoint=http://localhost:10000/devstoreaccount1;
# BLOB_ACCOUNT_URL=https://<account>.blob.core.windows.net
BLOB_PUBLISHED_CONTAINER=published
BLOB_ARCHIVE_CONTAINER=archive
BLOB_SNAPSHOTS_CONTAINER=snapshots

# ---- Redis ----
# Two auth modes:
#   1. URL-based (default). Embed credentials in REDIS_URL.
#      Local:           redis://localhost:6379/0
#      Azure (key):     rediss://:<PRIMARY_KEY>@<name>.redis.cache.windows.net:6380/0
#   2. Entra ID (passwordless). Set REDIS_USE_ENTRA=true + REDIS_HOST +
#      REDIS_ENTRA_USERNAME. REDIS_URL is ignored. `az login` is picked up locally.
REDIS_URL=redis://localhost:6379/0
# REDIS_USE_ENTRA=true
# REDIS_HOST=<name>.redis.cache.windows.net
# REDIS_PORT=6380
# REDIS_DB=0
# REDIS_SSL=true
# REDIS_ENTRA_USERNAME=<object-id of the principal with Redis Data Owner>

# ---- App ----
# AUTH_MODE:
#   stub      — header-based personas (X-User-Email). Requires LOCAL_DEV=1.
#   fake_oidc — self-signed JWT, tests only. Requires LOCAL_DEV=1.
#   oidc      — real Entra ID. Required in production. See ENTRA_* below.
AUTH_MODE=stub
# LOCAL_DEV=1 unlocks AUTH_MODE=stub/fake_oidc; never set in cloud.
LOCAL_DEV=1
# CLASSIFIER_PROVIDER:
#   stub   — deterministic local classifier, zero Azure calls. Default for dev.
#   llm    — Azure AI Foundry via Microsoft Agent Framework. Requires
#            AZURE_AI_PROJECT_ENDPOINT + FOUNDRY_DEPLOYMENT below.
CLASSIFIER_PROVIDER=stub
MAX_BUNDLE_BYTES=10485760
CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=INFO

# Manager / admin allowlist (comma-separated emails) — stub auth only.
# Under AUTH_MODE=oidc, admin role is sourced from the Entra group below.
MANAGER_EMAILS=manager@org
ADMIN_EMAILS=admin@org

# ---- Entra ID OIDC (only when AUTH_MODE=oidc) ----
# Provision with: scripts/setup-entra.sh <env> [<frontend-hostname>]
# Backend validates tokens whose `aud` matches ENTRA_CLIENT_ID (the API app).
# Admin role is granted to any user whose `groups` claim contains
# ENTRA_GROUP_ID_ADMIN (the skillhub-admins-<env> security group).
# ENTRA_TENANT_ID=<tenant guid>
# ENTRA_CLIENT_ID=<API app guid>
# ENTRA_GROUP_ID_ADMIN=<admin group object id>

# ---- Azure AI Foundry (classifier + curator LLM) ----
# Used when CLASSIFIER_PROVIDER=llm or CURATOR_REVIEW_PROVIDER=foundry.
# Passwordless: leave AZURE_AI_FOUNDRY_API_KEY empty and DefaultAzureCredential
# (`az login` / Managed Identity) is used. Your principal needs the
# "Cognitive Services User" role on the AI Services account.
#
# Both the classifier and curator review pass go through Microsoft Agent
# Framework's FoundryChatClient against a Foundry **Project** endpoint:
#   https://<acct>.services.ai.azure.com/api/projects/<project-name>
# Discover via:
#   az rest --method GET --url \
#     'https://management.azure.com/subscriptions/<sub>/resourceGroups/<rg>/providers/Microsoft.CognitiveServices/accounts/<acct>/projects?api-version=2025-04-01-preview'
# FOUNDRY_DEPLOYMENT=gpt-4o
# AZURE_AI_FOUNDRY_API_KEY=
# AZURE_AI_PROJECT_ENDPOINT=https://<acct>.services.ai.azure.com/api/projects/<project>

# ---- Curator review (M3) ----
# Aux LLM pass that suggests stale/archive transitions. Scheduler is off by
# default; on-demand POST /v1/admin/curator/review still works when disabled.
# Flip CURATOR_REVIEW_ENABLED=true and run `python -m backend.workers.curator_scheduler`
# to enable cron-driven runs.
# CURATOR_REVIEW_PROVIDER=foundry
# CURATOR_REVIEW_ENABLED=false

# ---- M5: Defender + Notifier (placeholders; no worker code yet) ----
# Terminal bucket for skills an admin rejects as malicious. The ONE
# container where delete-after-N-days is permitted (AGENTS.md §5).
QUARANTINE_CONTAINER=quarantine
# Azure Communication Services connection string. In prod this is mounted
# from Key Vault (`acs-connection-string`); for local dev the notifier
# worker is not wired up yet (M5-2). Leave this placeholder in .env.local.
ACS_CONNECTION_STRING=endpoint=https://placeholder.communication.azure.com/;accesskey=placeholder
